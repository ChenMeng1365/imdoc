                    "raw": "{\n  \"start\": \"ip pool\",\n  \"finish\": \"#\",\n  \"text\": \"aaa\\n  domain uni_static\\n    authentication-scheme default0\\n    accounting-scheme default0\\n    ip-pool static-1\\n    ip-pool static-2\\n    user-group static\\n  #\\n  domain uni_static_permit\\n    authentication-scheme default0\\n    accounting-scheme default0\\n    ip-pool static-1\\n    ip-pool static-2\\n    user-group static_permit\\n  #\\n#\\nip pool static-2 bas local\\n  gateway 100.100.100.1 255.255.255.0\\n  section 0 100.100.100.2 100.100.100.254\\n  excluded-ip-address 100.100.100.2 100.100.100.254\\n  dns-server 8.8.8.8 114.114.114.114\\n#\\ninterface Eth-Trunk5.26390409\\n  description USER::STATIC-USER-NUMBER::USERNAME.CO::50M\\n  statistic enable\\n  user-vlan 409 qinq 2639\\n  bas\\n    access-type layer2-subscriber default-domain authentication uni_static\\n    authentication-method bind\\n    qos-profile uni_50m inbound pe-vid 2639 ce-vid 409 identifier none\\n    qos-profile uni_50m outbound pe-vid 2639 ce-vid 409 identifier none\\n    arp-proxy\\n    ip-trigger\\n    arp-trigger\\n  #\\n#\\nstatic-user STATIC_USER_NUMBER 100.100.100.32 100.100.100.34 gateway 100.100.100.1 interface Eth-Trunk5.26390409 vlan 409 qinq 2639 domain-name uni_static detect\"\n}"
